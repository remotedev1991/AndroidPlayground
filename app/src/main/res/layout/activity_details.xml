<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailsActivity">

    <Button
        android:id="@+id/launch_gallery_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Details Screen \n\n Launch Gallery Button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/set_result_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set Result Button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/launch_gallery_button" />


    <Button
        android:id="@+id/set_no_result_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set No Result Button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/set_result_button" />

</androidx.constraintlayout.widget.ConstraintLayout>